pkgname=heroic-games-launcher-bin
pkgver=2.20.1
pkgrel=1
pkgdesc="An Open source Launcher for Epic, Amazon and GOG Games"
arch=('x86_64')
url="https://heroicgameslauncher.com/"
license=('GPL-3.0-only')
_filename="Heroic-${pkgver}-linux-x64.pacman"
source=("https://github.com/Heroic-Games-Launcher/HeroicGamesLauncher/releases/download/v${pkgver}/${_filename}")
noextract=("$_filename")
sha256sums=('SKIP')
options=(!strip)
depends=(which)
provides=(heroic-games-launcher-bin)
conflicts=(heroic-games-launcher)

package() {
    tar -xJv -C "$pkgdir" -f "$srcdir/$_filename" usr opt
    mkdir -p "$pkgdir/usr/bin"
    ln -s "/opt/Heroic/heroic" "$pkgdir/usr/bin/heroic"
}
