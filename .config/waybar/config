{
  "height": 30,
  "margin": "10px 20px 0 20px",
  "modules-left": [
    "custom/shutdown",
    "custom/reboot",
    "custom/suspend",
    "sway/workspaces",
    "sway/mode",
    "sway/window"
  ],
  "modules-center": [],
  "exclusive": false,
  "modules-right": [
    "pulseaudio",
    "backlight",
    "network",
    "custom/vpn",
    "cpu",
    "memory",
    "battery",
    "clock",
    "tray"
  ],
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "sway/window": {
    "max-length": 50
  },
  "custom/vpn": {
    "format": "|    пП≠  {}",
    "tooltip-format": "{icon}",
    "exec": "~/.config/waybar/modules/vpn.sh",
    "return-type": "json",
    "tooltip": true,
    "interval": 5
  },
  "custom/shutdown": {
    "format": "пАС",
    "on-click": "shutdown now",
    "tooltip": false
  },
  "custom/reboot": {
    "format": "пАЮ",
    "on-click": "reboot",
    "tooltip": false
  },
  "custom/suspend": {
    "format": "пА£",
    "on-click": "/usr/local/bin/lock_screen.sh",
    "tooltip": false
  },
  "tray": {
    "spacing": 10
  },
  "clock": {
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "пБ≥  {:%Y-%m-%d   %H:%M}"
  },
  "cpu": {
    "format": "пЛЫ  {usage}%",
    "tooltip": false
  },
  "memory": {
    "format": "пФЄ  {percentage}%",
    "on-click": "sudo /usr/local/bin/gamemode/optimize.sh"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "пЧІ  {capacity}%",
    "format-plugged": "пЗ¶  {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "пЙД",
      "пЙГ",
      "пЙВ",
      "пЙБ",
      "пЙА"
    ]
  },
  "network": {
    "format-wifi": "пЗЂ  {signalStrength}%",
    "format-ethernet": "пЮЦ  {ipaddr}",
    "on-click": "cmst",
    "format-linked": "пЮЦ  {ifname} (No IP)",
    "format-disconnected": "вЪ†  Disconnected"
  },
  "backlight": {
    "format": "",
    "format-icons": [
      "оОН",
      "оПУ",
      "оПС",
      "оПП",
      "оПО",
      "оПН",
      "оПК",
      "оПИ",
      "оОЫ"
    ]
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%      {format_source}",
    "format-bluetooth": "{icon}  {volume}%  {format_source}",
    "format-bluetooth-muted": "пЪ©  {icon}  {format_source}",
    "format-muted": "пЪ©   {format_source}",
    "format-source": "пД∞  {volume}%",
    "format-source-muted": "пД±",
    "scroll-step": 5,
    "format-icons": {
      "headphone": "пА•",
      "hands-free": "пЦР",
      "headset": "пЦР",
      "phone": "пВХ",
      "portable": "пВХ",
      "car": "пЖє",
      "default": [
        "пА¶",
        "пАІ",
        "пА®"
      ]
    },
    "on-click": "pavucontrol"
  }
}
