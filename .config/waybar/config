{
  "height": 30,
  "margin": "10px 20px 0 20px",
  "modules-left": [
    "custom/shutdown",
    "custom/reboot",
    "custom/suspend",
    "sway/workspaces",
    "sway/mode",
    "sway/window"
  ],
  "modules-center": [],
  "exclusive": false,
  "modules-right": [
    "pulseaudio",
    "backlight",
    "network",
    "custom/vpn",
    "cpu",
    "memory",
    "battery",
    "clock",
    "tray"
  ],
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "sway/window": {
    "max-length": 50
  },
  "custom/vpn": {
    "format": "|    яПн  {}",
    "tooltip-format": "{icon}",
    "exec": "~/.config/waybar/modules/vpn.sh",
    "return-type": "json",
    "tooltip": true,
    "interval": 5
  },
  "custom/shutdown": {
    "format": "яАС",
    "on-click": "shutdown now",
    "tooltip": false
  },
  "custom/reboot": {
    "format": "яАЮ",
    "on-click": "reboot",
    "tooltip": false
  },
  "custom/suspend": {
    "format": "яАг",
    "on-click": "sh -c '(sleep 0.1s; swaylock)' & disown",
    "tooltip": false
  },
  "tray": {
    "spacing": 10
  },
  "clock": {
    "interval": 60,
    "format": "яБ│  {:%F   %H:%M}",
    "tooltip-format": "<small><tt>{calendar}</tt></small>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "format": {
        "months": "<span size='16pt' rise='16pt' color='#ffead3'><b>{}</b></span>",
        "days": "<span size='15pt' color='#e5eaf0'><b>{}</b></span>",
        "weeks": "<span color='#8fbbba'><b>W{:%U}</b></span>",
        "weekdays": "<span size='15pt' color='#ffcc66'><b>{}</b></span>",
        "today": "<span size='15pt' color='#99ffdd'><b><u>{}</u></b></span>"
      }
    }
  },
  "cpu": {
    "format": "яЛЫ  {usage}%",
    "tooltip": false
  },
  "memory": {
    "format": "яФ╕  {percentage}%"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "яЧз  {capacity}%",
    "format-plugged": "яЗж  {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "яЙД",
      "яЙГ",
      "яЙВ",
      "яЙБ",
      "яЙА"
    ]
  },
  "network": {
    "format-wifi": "яЗл  {signalStrength}%",
    "format-ethernet": "яЮЦ  {ifname}",
    "on-click": "cmst",
    "format-linked": "яЮЦ  {ifname} (No IP)",
    "format-disconnected": "тЪа  Disconnected"
  },
  "backlight": {
    "format": "",
    "format-icons": [
      "юОН",
      "юПУ",
      "юПС",
      "юПП",
      "юПО",
      "юПН",
      "юПК",
      "юПИ",
      "юОЫ"
    ]
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%      {format_source}",
    "format-bluetooth": "{icon}  {volume}%  {format_source}",
    "format-bluetooth-muted": "яЪй  {icon}  {format_source}",
    "format-muted": "яЪй   {format_source}",
    "format-source": "яД░  {volume}%",
    "format-source-muted": "яД▒",
    "scroll-step": 5,
    "format-icons": {
      "headphone": "яАе",
      "hands-free": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": [
        "яАж",
        "яАз",
        "яАи"
      ]
    },
    "on-click": "pavucontrol"
  }
}
