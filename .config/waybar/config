{
  "height": 40,
  "modules-left": [
    "custom/shutdown",
    "custom/lock",
    "sway/workspaces",
    "sway/mode",
    "sway/window"
  ],
  "modules-center": [],
  "exclusive": false,
  "modules-right": [
    "pulseaudio",
    "backlight",
    "network",
    "cpu",
    "memory",
    "battery",
    "clock",
    "tray",
    "custom/space"
  ],
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "sway/window": {
    "max-length": 50
  },
  "custom/shutdown": {
    "format": "ΎΑΣ",
    "on-click": "shutdown now",
    "tooltip": false
  },
  "custom/lock": {
    "format": "ΎΑμ",
    "on-click": "swaylock-fancy",
    "tooltip": false
  },
  "custom/space": {
    "format": "<span></span>"
  },
  "tray": {
    "spacing": 10
  },
  "clock": {
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "ΎΒ│  {:%Y-%m-%d   %H:%M}"
  },
  "cpu": {
    "format": "ΎΜδ  {usage}%",
    "tooltip": false
  },
  "memory": {
    "format": "ΎΦ╕  {percentage}%",
    "on-click": "sudo ~/.my-scripts/free-os-cache.sh"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "ΎΩπ  {capacity}%",
    "format-plugged": "ΎΘο  {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "ΎΚΕ",
      "ΎΚΔ",
      "ΎΚΓ",
      "ΎΚΒ",
      "ΎΚΑ"
    ]
  },
  "network": {
    "format-wifi": "ΎΘτ  {signalStrength}%",
    "format-ethernet": "ΎηΨ  {ipaddr}",
    "on-click": "cmst",
    "format-linked": "ΎηΨ  {ifname} (No IP)",
    "format-disconnected": "έγι  Disconnected"
  },
  "backlight": {
    "format": "",
    "format-icons": [
      "ΌΟΞ",
      "ΌΠΥ",
      "ΌΠΣ",
      "ΌΠΠ",
      "ΌΠΟ",
      "ΌΠΞ",
      "ΌΠΛ",
      "ΌΠΙ",
      "ΌΟδ"
    ]
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%      {format_source}",
    "format-bluetooth": "{icon}  {volume}%  {format_source}",
    "format-bluetooth-muted": "Ύγσ  {icon}  {format_source}",
    "format-muted": "Ύγσ   {format_source}",
    "format-source": "ΎΕ░  {volume}%",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΨΡ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "ΎΑρ"
      ]
    },
    "on-click": "pavucontrol"
  }
}
